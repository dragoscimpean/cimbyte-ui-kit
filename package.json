{
  "name": "@cimbyte/ui",
  "version": "0.2.0",
  "description": "Cimbyte UI — cross-platform design tokens, standalone CSS and vanilla JS behaviors.",
  "type": "module",
  "main": "cimbyte.js",
  "style": "cimbyte.css",
  "exports": {
    ".": "./cimbyte.js",
    "./css": "./cimbyte.css",
    "./cimbyte.css": "./cimbyte.css",
    "./tokens": "./tokens/cimbyte.tokens.json"
  },
  "files": ["cimbyte.css", "cimbyte.js", "tokens/cimbyte.tokens.json", "README.md", "CHANGELOG.md", "LICENSE", "THIRD_PARTY_NOTICES.md"],
  "sideEffects": ["*.css", "cimbyte.js"],
  "scripts": {
    "generate": "node scripts/generate-tokens.mjs",
    "generate:check": "node scripts/generate-tokens.mjs --check",
    "check": "npm run generate:check && node --check cimbyte.js && node --check scripts/generate-tokens.mjs",
    "android:assemble": "cd android && ./gradlew :cimbyte-ui-compose:assembleRelease",
    "android:publish-local": "cd android && ./gradlew :cimbyte-ui-compose:publishToMavenLocal",
    "demo": "python3 -m http.server 4180 --directory ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragoscimpean/cimbyte-ui-kit.git"
  },
  "homepage": "https://github.com/dragoscimpean/cimbyte-ui-kit#readme",
  "bugs": "https://github.com/dragoscimpean/cimbyte-ui-kit/issues",
  "keywords": ["design-system", "css", "android", "jetpack-compose", "ui-kit"],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
